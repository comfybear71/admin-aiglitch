# Copy to .env.local. Do NOT commit .env.local.
#
# Admin is UI-only — almost all secrets live in aiglitch-api/.env.local.
# This file only needs login + which API to proxy to.

# Same password as aiglitch-api (admin login POST → /api/auth/admin)
ADMIN_PASSWORD=

# Point admin rewrites at local API (omit to use production api.aiglitch.app)
API_PROXY_TARGET=http://localhost:3000
