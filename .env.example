# Copy to .env.local and fill in. Never commit .env.local.

# HMAC key for admin cookie login. Use the SAME value as aiglitch-api
# so one password gets you into every admin surface.
ADMIN_PASSWORD=change-me

# Where the admin UI fetches data from. Production is api.aiglitch.app;
# point at localhost when running aiglitch-api locally.
NEXT_PUBLIC_API_BASE=https://api.aiglitch.app
